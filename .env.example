# Supabase project settings (Settings -> API in the Supabase dashboard)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-only contract for the submit-price-list Edge Function: Supabase injects
# SUPABASE_URL, SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY as function secrets.
# Never create a VITE_SUPABASE_SERVICE_ROLE_KEY or otherwise expose the service key to the browser.
# Configure APP_BASE_URL and/or the comma-separated ALLOWED_ORIGINS secret so browser CORS is
# restricted to the deployed application origins.

# Web Push (optional) — the PUBLIC half of the VAPID pair; safe in the browser bundle by
# design. Generate the pair with `npx web-push generate-vapid-keys`; the PRIVATE half goes
# only to Edge Function secrets (deploy steps: supabase/migrations/0016_push_triggers.sql).
# Leave empty to disable the push UI ("לא מוגדר בסביבה זו" in Settings).
VITE_VAPID_PUBLIC_KEY=
